{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "FMJ HOLDINGS",
  "version": "0.1.3",
  "identifier": "com.fmjpro.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "FMJ HOLDINGS",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/FMJHOLDINGS/FMJ/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDg1REVDQUExQUI3MkQxODEKUldTQjBYS3JvY3JlaFJDaHpKTXVZQkZCc3NnWUNZU2VRc2ROY0FuditJZHRTR0JGaHBpYlFHajYK"
    }
  }
}